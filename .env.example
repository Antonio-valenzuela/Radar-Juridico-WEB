# Runtime ---------------------------------------------------------------------
NODE_ENV=development
PORT=3000
HOSTNAME=0.0.0.0
FRONTEND_PORT=3100
NEXT_PUBLIC_APP_URL=http://localhost:3100
NEXT_PUBLIC_ENABLE_PUBLIC_DEMO=false
NEXT_PUBLIC_WEBSOCKET_URL=
NEXT_DIST_DIR=.next
NEXT_TELEMETRY_DISABLED=1

# PostgreSQL / pgvector --------------------------------------------------------
# En producción reemplaza usuario, contraseña y base con valores aleatorios.
POSTGRES_USER=radar_local
POSTGRES_PASSWORD=replace-with-random-password
POSTGRES_DB=juridico_local
DATABASE_URL=postgresql://radar_local:replace-with-random-password@localhost:5432/juridico_local?schema=public

# Redis -----------------------------------------------------------------------
REDIS_PASSWORD=replace-with-random-password
REDIS_URL=redis://:replace-with-random-password@localhost:6379/0

# Authorization and feature exposure -----------------------------------------
ADMIN_TOKEN=replace-with-random-token
ENABLE_PUBLIC_DEMO=false
ENABLE_PUBLIC_AI=false
ENABLE_PUBLIC_SEARCH=false
ENABLE_PUBLIC_DOCUMENTS=false

# Process switches and internal health ports ---------------------------------
ENABLE_WORKERS=true
ENABLE_AUTO_INGEST=true
ENABLE_DASHBOARD_WS=true
WEBSOCKET_PORT=3002
WORKER_HEALTH_PORT=9101
LEGAL_REPORT_WORKER_HEALTH_PORT=9102

# Official legal sources / ingest --------------------------------------------
SIDOF_BASE_URL=https://sidof.segob.gob.mx/dof/sidof
SJF_START_ID=2033000
LEGAL_RADAR_LOOKBACK_DAYS=7
INGEST_DEFAULT_DAYS=7
INGEST_MAX_LIMIT=200
CRAWLER_TIMEOUT_MS=30000

# Notifications ---------------------------------------------------------------
NOTIFY_TEST_EMAIL=
RESEND_API_KEY=
FROM_EMAIL=alerts@juridico-radar.local
WEBHOOK_URL=
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=Jurídico Radar <no-reply@juridico-radar.local>

# AI provider routing ---------------------------------------------------------
LLM_PROVIDER=local
AI_PROVIDER_CHAIN=gemini,groq,openrouter,local
AI_SELECTION_STRATEGY=ordered
AI_ENABLE_USAGE_TRACKING=true
AI_LOCAL_DAILY_LIMIT=20
AI_USAGE_TIMEZONE=America/Mexico_City
AI_ENABLE_EXTERNAL_CONTEXT=false
AI_ENABLE_VISION=false
AI_WEEKLY_DIGEST_DAYS=7

# AI providers; leave empty when unused --------------------------------------
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash
GROQ_API_KEY=
GROQ_MODEL=llama-3.1-8b-instant
OPENROUTER_API_KEY=
OPENROUTER_MODEL=openai/gpt-oss-20b:free
OPENAI_API_KEY=
EMBEDDINGS_PROVIDER=local
EMBEDDINGS_MODEL=text-embedding-ada-002
TAVILY_API_KEY=
SEARCH_PROVIDER=none
VISION_PROVIDER=none

# Timeouts in milliseconds ----------------------------------------------------
AI_REQUEST_TIMEOUT_MS=20000
AI_PROVIDER_TIMEOUT_MS=8000
AI_GLOBAL_TIMEOUT_MS=20000
TIMEOUT_LOCAL_SEARCH_MS=3000
TIMEOUT_PER_SOURCE_MS=1500
TIMEOUT_EXTERNAL_SEARCH_MS=6000
TIMEOUT_LOCAL_VERSIONS_MS=3000
TIMEOUT_WEEKLY_DIFFS_MS=3000
TIMEOUT_LLM_EXPANSION_MS=4000
TIMEOUT_AI_SYNTHESIS_MS=5000
TIMEOUT_INGEST_FETCH_MS=10000
TIMEOUT_INGEST_RUN_MS=120000

# Reserved for future token-based auth; currently not consumed by the app ----
JWT_SECRET=replace-with-random-token
REFRESH_TOKEN_SECRET=replace-with-random-token
