# Jurídico Radar - Environment Variables Template

# Database connection
DATABASE_URL=postgresql://user:pass@localhost:5432/juridico

# Admin security token for triggering ingestion
ADMIN_TOKEN=secreto123
NEXT_PUBLIC_ADMIN_TOKEN=secreto123

# API Base URLs
SIDOF_BASE_URL=https://sidof.segob.gob.mx/dof/sidof

# Optional: Redis for background jobs (BullMQ)
REDIS_URL=redis://localhost:6379
