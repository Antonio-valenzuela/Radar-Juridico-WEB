NODE_ENV=development
FRONTEND_PORT=3100
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_DIST_DIR=.next

DATABASE_URL=postgresql://app:apppass@localhost:5432/juridico?schema=public
REDIS_URL=redis://localhost:6379

ADMIN_TOKEN=change-me-in-local-dev
JWT_SECRET=change-me-in-local-dev
REFRESH_TOKEN_SECRET=change-me-in-local-dev

INGEST_DEFAULT_DAYS=7
INGEST_MAX_LIMIT=200

SIDOF_BASE_URL=https://sidof.segob.gob.mx/dof/sidof
SJF_START_ID=2033000

NOTIFY_TEST_EMAIL=
RESEND_API_KEY=
FROM_EMAIL=alerts@juridico-radar.local

WEBHOOK_URL=
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=Jurídico Radar <no-reply@juridico-radar.local>

# AI provider
LLM_PROVIDER=local

# Gemini
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

# OpenRouter
OPENROUTER_API_KEY=
OPENROUTER_MODEL=openai/gpt-oss-20b:free

# Groq
GROQ_API_KEY=
GROQ_MODEL=llama-3.1-8b-instant

# Timeouts — AI provider chain
AI_PROVIDER_TIMEOUT_MS=8000
AI_GLOBAL_TIMEOUT_MS=20000

# Timeouts — Search steps (0 = disabled, only in non-production)
TIMEOUT_LOCAL_SEARCH_MS=3000
TIMEOUT_PER_SOURCE_MS=1500
TIMEOUT_EXTERNAL_SEARCH_MS=6000
TIMEOUT_LOCAL_VERSIONS_MS=3000
TIMEOUT_WEEKLY_DIFFS_MS=3000
TIMEOUT_LLM_EXPANSION_MS=4000
TIMEOUT_AI_SYNTHESIS_MS=5000

# Timeouts — Ingest
TIMEOUT_INGEST_FETCH_MS=10000
TIMEOUT_INGEST_RUN_MS=120000

# AI task routing
AI_PROVIDER_CHAIN=gemini,groq,openrouter,local
AI_ENABLE_USAGE_TRACKING=true
AI_LOCAL_DAILY_LIMIT=20
AI_USAGE_TIMEZONE=America/Mexico_City
AI_ENABLE_EXTERNAL_CONTEXT=false
AI_ENABLE_VISION=false
AI_WEEKLY_DIGEST_DAYS=7

# Future providers
TAVILY_API_KEY=
SEARCH_PROVIDER=none
VISION_PROVIDER=none
